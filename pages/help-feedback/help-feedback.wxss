.help-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.help-section, .contact-section, .feedback-section {
  background: #ffffff;
  margin-bottom: 20rpx;
}

.section-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-tip {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.help-list {
  padding: 0 30rpx;
}

.help-item {
  border-bottom: 1rpx solid #f0f0f0;
}

.help-item:last-child {
  border-bottom: none;
}

.help-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
}

.question-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  margin-right: 20rpx;
}

.question-arrow {
  font-size: 20rpx;
  color: #999999;
  transition: transform 0.3s ease;
}

.question-arrow.expanded {
  transform: rotate(180deg);
}

.help-answer {
  padding: 0 0 30rpx;
  background: #fafafa;
  margin: 0 -30rpx 0;
  padding: 24rpx 30rpx;
}

.answer-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  white-space: pre-wrap;
}

.contact-section .section-header {
  border-bottom: none;
}

.contact-card {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-card:last-child {
  border-bottom: none;
}

.contact-icon-box {
  width: 72rpx;
  height: 72rpx;
  background: #f0f7ff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
}

.contact-icon {
  font-size: 36rpx;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.contact-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 6rpx;
}

.contact-value {
  font-size: 28rpx;
  color: #333333;
}

.contact-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

.feedback-form {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
}

.form-textarea {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333333;
  min-height: 200rpx;
  line-height: 1.6;
}

.word-count {
  text-align: right;
  margin-top: 12rpx;
}

.count-text {
  font-size: 24rpx;
  color: #999999;
}

.form-input {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333333;
}

.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  height: 100rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.4);
}

.submit-btn.disabled {
  opacity: 0.6;
}

.submit-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
}

.bottom-spacer {
  height: 60rpx;
}
