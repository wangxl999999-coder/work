<scroll-view class="info-container" scroll-y>
  <view class="info-form">
    <view class="form-section">
      <text class="section-title">基本信息</text>
      
      <view class="avatar-section">
        <view class="user-avatar">
          <text class="avatar-text" wx:if="{{nickname}}">{{nickname[0]}}</text>
          <text class="avatar-text" wx:else>用</text>
        </view>
        <text class="avatar-tip">点击更换头像</text>
      </view>
      
      <view class="form-item">
        <text class="form-label">昵称</text>
        <input 
          class="form-input" 
          type="text" 
          placeholder="请输入昵称" 
          value="{{nickname}}" 
          bindinput="onNicknameInput"
          maxlength="20"
        />
      </view>
    </view>

    <view class="form-section">
      <text class="section-title">求职意向</text>
      <text class="section-tip">完善求职意向，帮您更快找到合适的工作</text>
      
      <view class="form-item" bindtap="openCityPicker">
        <text class="form-label">期望城市</text>
        <view class="picker-row">
          <text class="picker-value {{expectedCity ? '' : 'placeholder'}}">
            {{expectedCity || '请选择期望工作城市'}}
          </text>
          <text class="picker-arrow">›</text>
        </view>
      </view>

      <view class="form-item" bindtap="openJobPicker">
        <text class="form-label">期望岗位</text>
        <view class="picker-row">
          <text class="picker-value {{expectedJob ? '' : 'placeholder'}}">
            {{expectedJob || '请选择期望工作岗位'}}
          </text>
          <text class="picker-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="save-btn" bindtap="saveInfo">
      <text class="btn-text">保存</text>
    </view>
  </view>
</scroll-view>

<picker-view wx:if="{{cityPickerVisible}}" class="picker-mask" bindtap="closeCityPicker">
  <view class="picker-container" catchtap="">
    <view class="picker-header">
      <view class="picker-cancel" bindtap="clearCity">
        <text class="cancel-text">清空</text>
      </view>
      <text class="picker-title">选择城市</text>
      <view class="picker-confirm" bindtap="closeCityPicker">
        <text class="confirm-text">确定</text>
      </view>
    </view>
    <picker-view class="picker-view" indicator-style="height: 80rpx;" value="{{[selectedCityIndex]}}" bindchange="onCityChange">
      <picker-view-column>
        <view wx:for="{{cityColumns}}" wx:key="index" class="picker-item">{{item}}</view>
      </picker-view-column>
    </picker-view>
  </view>
</picker-view>

<picker-view wx:if="{{jobPickerVisible}}" class="picker-mask" bindtap="closeJobPicker">
  <view class="picker-container" catchtap="">
    <view class="picker-header">
      <view class="picker-cancel" bindtap="clearJob">
        <text class="cancel-text">清空</text>
      </view>
      <text class="picker-title">选择岗位</text>
      <view class="picker-confirm" bindtap="closeJobPicker">
        <text class="confirm-text">确定</text>
      </view>
    </view>
    <picker-view class="picker-view" indicator-style="height: 80rpx;" value="{{[selectedJobIndex]}}" bindchange="onJobChange">
      <picker-view-column>
        <view wx:for="{{jobColumns}}" wx:key="index" class="picker-item">{{item}}</view>
      </picker-view-column>
    </picker-view>
  </view>
</picker-view>
