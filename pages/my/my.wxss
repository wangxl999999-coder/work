.my-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.user-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 30rpx 80rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.avatar-text {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 500;
}

.user-detail {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.user-phone {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.user-tags {
  display: flex;
  flex-wrap: wrap;
}

.user-tags .tag {
  font-size: 22rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.arrow-icon {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 16rpx;
}

.login-prompt {
  display: flex;
  align-items: center;
}

.login-avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.login-icon {
  font-size: 56rpx;
}

.login-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.login-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.login-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-section {
  display: flex;
  background: #ffffff;
  border-radius: 24rpx;
  margin: -40rpx 30rpx 30rpx;
  padding: 40rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 26rpx;
  color: #999999;
}

.stats-divider {
  width: 1rpx;
  height: 80rpx;
  background: #eeeeee;
}

.menu-section {
  margin: 0 30rpx 30rpx;
}

.menu-group {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-badge {
  background: #e53935;
  border-radius: 20rpx;
  padding: 4rpx 12rpx;
  margin-right: 8rpx;
  min-width: 32rpx;
  text-align: center;
}

.badge-text {
  font-size: 20rpx;
  color: #ffffff;
}

.menu-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

.logout-section {
  margin: 40rpx 30rpx;
}

.logout-btn {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
}

.logout-text {
  font-size: 32rpx;
  color: #e53935;
}

.version-section {
  text-align: center;
  padding: 40rpx 0;
}

.version-text {
  font-size: 24rpx;
  color: #cccccc;
}
