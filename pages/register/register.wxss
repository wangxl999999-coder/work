.register-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.register-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx 80rpx;
}

.title-text {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.sub-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.register-form {
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  padding: 40rpx 32rpx;
}

.form-section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.section-tip {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
}

.input-row {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 96rpx;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 96rpx;
}

.code-btn {
  background: #1A73E8;
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  margin-left: 16rpx;
}

.code-btn.disabled {
  background: #cccccc;
}

.code-btn text {
  font-size: 26rpx;
  color: #ffffff;
}

.eye-icon {
  padding: 10rpx;
  font-size: 36rpx;
}

.picker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 96rpx;
}

.picker-value {
  font-size: 30rpx;
  color: #333333;
}

.picker-value.placeholder {
  color: #999999;
}

.picker-arrow {
  font-size: 36rpx;
  color: #999999;
}

.agreement-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
  margin-left: 8rpx;
}

.agreement-link {
  color: #1A73E8;
}

.form-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  height: 100rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.4);
}

.btn-text {
  font-size: 34rpx;
  font-weight: 500;
  color: #ffffff;
}

.login-link {
  display: flex;
  justify-content: center;
  align-items: center;
  padding-bottom: 40rpx;
}

.link-text {
  font-size: 28rpx;
  color: #666666;
}

.link-text.highlight {
  color: #1A73E8;
  margin-left: 8rpx;
  font-weight: 500;
}

.picker-view {
  width: 100%;
  height: 500rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  z-index: 1000;
}

.picker-item {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 80rpx;
  font-size: 30rpx;
  color: #333333;
}
