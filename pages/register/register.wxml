<scroll-view class="register-container" scroll-y>
  <view class="register-header">
    <text class="title-text">创建账号</text>
    <text class="sub-text">完善信息，开始您的求职之旅</text>
  </view>

  <view class="register-form">
    <view class="form-section">
      <text class="section-title">基础信息</text>
      
      <view class="form-item">
        <text class="form-label">手机号</text>
        <view class="input-row">
          <input 
            class="form-input" 
            type="number" 
            placeholder="请输入手机号" 
            value="{{phone}}" 
            bindinput="onPhoneInput"
            maxlength="11"
          />
          <view class="code-btn {{codeDisabled ? 'disabled' : ''}}" bindtap="getCode">
            <text>{{codeText}}</text>
          </view>
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">验证码</text>
        <input 
          class="form-input" 
          type="number" 
          placeholder="请输入验证码" 
          value="{{code}}" 
          bindinput="onCodeInput"
          maxlength="6"
        />
      </view>

      <view class="form-item">
        <text class="form-label">昵称</text>
        <input 
          class="form-input" 
          type="text" 
          placeholder="请输入昵称" 
          value="{{nickname}}" 
          bindinput="onNicknameInput"
        />
      </view>

      <view class="form-item">
        <text class="form-label">密码</text>
        <view class="input-row">
          <input 
            class="form-input" 
            type="{{showPassword ? 'text' : 'password'}}" 
            placeholder="请设置6-20位密码" 
            value="{{password}}" 
            bindinput="onPasswordInput"
          />
          <view class="eye-icon" bindtap="togglePassword">
            <text>{{showPassword ? '🙈' : '👁️'}}</text>
          </view>
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">确认密码</text>
        <view class="input-row">
          <input 
            class="form-input" 
            type="{{showConfirmPassword ? 'text' : 'password'}}" 
            placeholder="请再次输入密码" 
            value="{{confirmPassword}}" 
            bindinput="onConfirmPasswordInput"
          />
          <view class="eye-icon" bindtap="toggleConfirmPassword">
            <text>{{showConfirmPassword ? '🙈' : '👁️'}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="form-section">
      <text class="section-title">求职意向</text>
      <text class="section-tip">（选填，帮助您更快找到合适的工作）</text>
      
      <view class="form-item" bindtap="openCityPicker">
        <text class="form-label">期望城市</text>
        <view class="picker-row">
          <text class="picker-value {{expectedCity ? '' : 'placeholder'}}">
            {{expectedCity || '请选择期望工作城市'}}
          </text>
          <text class="picker-arrow">›</text>
        </view>
      </view>

      <view class="form-item" bindtap="openJobPicker">
        <text class="form-label">期望岗位</text>
        <view class="picker-row">
          <text class="picker-value {{expectedJob ? '' : 'placeholder'}}">
            {{expectedJob || '请选择期望工作岗位'}}
          </text>
          <text class="picker-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="agreement-row">
      <checkbox color="#1A73E8" checked />
      <text class="agreement-text">
        我已阅读并同意
        <text class="agreement-link">《用户协议》</text>
        和
        <text class="agreement-link">《隐私政策》</text>
      </text>
    </view>

    <view class="form-btn" bindtap="doRegister">
      <text class="btn-text">注册</text>
    </view>

    <view class="login-link" bindtap="goToLogin">
      <text class="link-text">已有账号？</text>
      <text class="link-text highlight">立即登录</text>
    </view>
  </view>
</scroll-view>

<picker-view wx:if="{{cityPickerVisible}}" class="picker-view" indicator-style="height: 80rpx;" value="{{[0]}}" bindchange="onCityChange">
  <picker-view-column>
    <view wx:for="{{cityColumns}}" wx:key="index" class="picker-item">{{item}}</view>
  </picker-view-column>
</picker-view>

<picker-view wx:if="{{jobPickerVisible}}" class="picker-view" indicator-style="height: 80rpx;" value="{{[0]}}" bindchange="onJobChange">
  <picker-view-column>
    <view wx:for="{{jobColumns}}" wx:key="index" class="picker-item">{{item}}</view>
  </picker-view-column>
</picker-view>
